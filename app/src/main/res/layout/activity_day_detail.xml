<?xml version="1.0" encoding="utf-8"?>
<!-- Fiche journée en LECTURE SEULE (sections construites dynamiquement). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <Button
            android:id="@+id/dd_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/day_back" />

        <TextView
            android:id="@+id/dd_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textColor="@color/title"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dd_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Navigation entre les événements du jour -->
        <LinearLayout
            android:id="@+id/dd_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/dd_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀" />

            <TextView
                android:id="@+id/dd_counter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/dd_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶" />
        </LinearLayout>

        <!-- Corps : rempli dynamiquement (coordonnées, essai, lieu, horaires, récap) -->
        <LinearLayout
            android:id="@+id/dd_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp" />

        <TextView
            android:id="@+id/dd_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="@string/day_empty"
            android:textColor="@color/muted"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
