<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/dd_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/day_back" />

        <TextView
            android:id="@+id/dd_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textColor="@color/title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Navigation entre les événements de la journée -->
        <LinearLayout
            android:id="@+id/dd_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <Button
                android:id="@+id/dd_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀" />

            <TextView
                android:id="@+id/dd_counter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/dd_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶" />
        </LinearLayout>

        <TextView
            android:id="@+id/dd_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textColor="@color/required"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dd_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dd_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp" />

        <Button
            android:id="@+id/dd_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/dd_mail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/dd_site"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/open_site" />

        <TextView
            android:id="@+id/dd_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="@string/day_empty"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
