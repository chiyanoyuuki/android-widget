<?xml version="1.0" encoding="utf-8"?>
<!--
  Une case du calendrier (look « teinté » du nouveau IntraCCB2) :
  fond + bord teintés dynamiquement (setColorFilter), numéro, anneau « aujourd'hui »,
  badge multi-événements et pastilles « essai/planning manquant ».
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cell_root"
    android:layout_width="match_parent"
    android:layout_height="46dp"
    android:padding="1dp">

    <!-- Fond (blanc, teinté par colorFilter) -->
    <ImageView
        android:id="@+id/cell_fill"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/cell_shape" />

    <!-- Bord (blanc, teinté par colorFilter) -->
    <ImageView
        android:id="@+id/cell_stroke"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/cell_stroke" />

    <!-- Anneau « aujourd'hui » (mauve, fixe) -->
    <ImageView
        android:id="@+id/cell_today"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/cell_ring_today"
        android:visibility="gone" />

    <!-- Numéro du jour -->
    <TextView
        android:id="@+id/cell_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Badge nombre d'événements (> 1) -->
    <TextView
        android:id="@+id/cell_badge"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:gravity="center"
        android:background="@drawable/badge_background"
        android:textColor="@android:color/white"
        android:textSize="9sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Pastilles « manque essai / planning » -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="3dp"
        android:layout_marginBottom="3dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/cell_essai"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="3dp"
            android:background="@drawable/dot_warning"
            android:contentDescription="@null"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/cell_planning"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_planning"
            android:contentDescription="@null"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
