<?xml version="1.0" encoding="utf-8"?>
<!-- Une case du calendrier : fond coloré + bord marqueur + numéro + badge multi-événements -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cell_root"
    android:layout_width="match_parent"
    android:layout_height="40dp">

    <!-- Fond (couleur du statut, défini dynamiquement) -->
    <View
        android:id="@+id/cell_fill"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bord spécial : aujourd'hui / manque planning / manque essai -->
    <View
        android:id="@+id/cell_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Numéro du jour -->
    <TextView
        android:id="@+id/cell_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Badge nombre d'événements (> 1) -->
    <TextView
        android:id="@+id/cell_badge"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_gravity="top|end"
        android:gravity="center"
        android:background="@drawable/badge_background"
        android:textColor="@android:color/white"
        android:textSize="9sp"
        android:textStyle="bold"
        android:visibility="gone" />
</FrameLayout>
