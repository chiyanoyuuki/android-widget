<?xml version="1.0" encoding="utf-8"?>
<!-- Widget "prochain événement" : en-tête navigable + carte de détails -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- En-tête : ◀ | compteur | ▶ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/event_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="◀"
            android:textColor="@color/title"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/event_counter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/event_title"
            android:textColor="@color/title"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/event_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="▶"
            android:textColor="@color/title"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Contenu de l'événement (tap ailleurs -> ouvre l'intra) -->
    <LinearLayout
        android:id="@+id/event_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="6dp">

        <TextView
            android:id="@+id/event_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/event_daycount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="1dp"
            android:textColor="@color/weekday"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/event_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/event_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:paddingBottom="4dp"
            android:textColor="@color/title"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/event_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF333333"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/event_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:textColor="@color/required"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/event_mail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="2dp"
            android:textColor="@color/required"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Aucun événement à venir -->
    <TextView
        android:id="@+id/event_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/event_empty"
        android:textColor="@color/weekday"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
